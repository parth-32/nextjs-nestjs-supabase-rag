# Compliance Copilot API — copy to backend/.env and fill in values.
# Server-only secrets. Never expose these to the frontend or commit .env.

# --- Supabase (service role — backend only) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

# --- Google Gemini ---
GEMINI_API_KEY=

# --- API ---
NODE_ENV=development
API_PORT=4000
# PORT is set automatically on Vercel; local dev uses API_PORT.
CORS_ORIGINS=http://localhost:3000
