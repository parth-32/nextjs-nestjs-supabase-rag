{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "corepack enable && pnpm install --frozen-lockfile",
  "experimentalServices": {
    "frontend": {
      "type": "web",
      "root": "frontend",
      "mount": "/",
      "framework": "nextjs",
      "buildCommand": "pnpm --filter @ccp/shared build && pnpm --filter @ccp/frontend build"
    },
    "backend": {
      "type": "web",
      "root": "backend",
      "mount": "/api",
      "framework": "nestjs",
      "buildCommand": "pnpm --filter @ccp/shared build && pnpm --filter @ccp/backend build",
      "includeFiles": "packages/shared/dist/**"
    }
  }
}
