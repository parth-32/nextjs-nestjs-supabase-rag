# Compliance Copilot web — copy to frontend/.env and fill in values.
# NEXT_PUBLIC_* vars are embedded in the client bundle. Use only public keys here.

# Local dev: point at the NestJS API on :4000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Vercel Services sets NEXT_PUBLIC_BACKEND_URL automatically (e.g. /api) — no need to set locally.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
